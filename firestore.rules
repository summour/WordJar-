rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WordJar private user data.
    // Allows each signed-in Firebase Auth user to read/write only their own data,
    // including nested backup chunks under backups/main/chunks/*.
    match /wordjarUsers/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
